        "validation": [
          {
            "rules": [
              {
                "flag": "valid",
                "constraint": [
                  "Cultural",
                  "Food",
                  "Celebrity",
                  "Short",
                  "Ayurveda",
                  "Homestay",
                  "Education",
                  "Industrial",
                  "Village",
                  "Cooking",
                  "Temple"
                ]
              },
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "name": "category",
        "type": "string"
      },
      {
        "rows": 3,
        "description": "Write 1-2 sentences max. First sentence appears on the tour hero panel. Keep it under 150 characters for best display.",
        "name": "shortDescription",
        "type": "text",
        "title": "Hero Description (shown on tour panel)"
      },
      {
        "rows": 10,
        "name": "longDescription",
        "type": "text",
        "title": "About This Tour"
      },
      {
        "name": "startDate",
        "type": "date"
      },
      {
        "name": "endDate",
        "type": "date"
      },
