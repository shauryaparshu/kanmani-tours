              "value": "Short"
            },
            {
              "title": "Ayurveda Tours",
              "value": "Ayurveda"
            },
            {
              "title": "Homestay with Indian Family",
              "value": "Homestay"
            },
            {
              "title": "Education Tours",
              "value": "Education"
            },
            {
              "title": "Industrial Tours",
              "value": "Industrial"
            },
            {
              "title": "Village Tours",
              "value": "Village"
